<odoo>
    <data>

        <record id="view_oilgas_equipment_list" model="ir.ui.view">
            <field name="name">oilgas.equipment.list</field>
            <field name="model">oilgas.equipment</field>
            <field name="arch" type="xml">
                <list string="Equipment"
                      decoration-success="status == 'operational'"
                      decoration-warning="status == 'under_maintenance'"
                      decoration-danger="status == 'faulty'"
                      decoration-muted="status == 'decommissioned'">
                    <field name="name"/>
                    <field name="serial_number"/>
                    <field name="location"/>
                    <field name="equipment_type"/>
                    <field name="technician_id"/>
                    <field name="status" widget="badge"
                           decoration-success="status == 'operational'"
                           decoration-warning="status == 'under_maintenance'"
                           decoration-danger="status == 'faulty'"/>
                </list>
            </field>
        </record>

        <record id="view_oilgas_equipment_form" model="ir.ui.view">
            <field name="name">oilgas.equipment.form</field>
            <field name="model">oilgas.equipment</field>
            <field name="arch" type="xml">
                <form string="Equipment">
                    <header>
                        <field name="status" widget="statusbar"
                               statusbar_visible="operational,under_maintenance,faulty,decommissioned"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Equipment Information">
                                <field name="name"/>
                                <field name="serial_number"/>
                                <field name="equipment_type"/>
                                <field name="location"/>
                            </group>
                            <group string="Assignment">
                                <field name="technician_id"/>
                                <field name="status"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Maintenance History">
                                <field name="maintenance_request_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="technician_id"/>
                                        <field name="request_date"/>
                                        <field name="priority"/>
                                        <field name="state" widget="badge"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_oilgas_equipment_search" model="ir.ui.view">
            <field name="name">oilgas.equipment.search</field>
            <field name="model">oilgas.equipment</field>
            <field name="arch" type="xml">
                <search string="Search Equipment">
                    <field name="name"/>
                    <field name="serial_number"/>
                    <field name="technician_id"/>
                    <filter string="Operational" name="filter_operational"
                            domain="[('status', '=', 'operational')]"/>
                    <filter string="Faulty" name="filter_faulty"
                            domain="[('status', '=', 'faulty')]"/>
                    <filter string="Under Maintenance" name="filter_maintenance"
                            domain="[('status', '=', 'under_maintenance')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_status"
                                context="{'group_by': 'status'}"/>
                        <filter string="Type" name="group_type"
                                context="{'group_by': 'equipment_type'}"/>
                        <filter string="Technician" name="group_technician"
                                context="{'group_by': 'technician_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_oilgas_equipment" model="ir.actions.act_window">
            <field name="name">Equipment</field>
            <field name="res_model">oilgas.equipment</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_filter_operational': 1}</field>
            <field name="help">Add your first piece of equipment!</field>
        </record>

    </data>
</odoo>